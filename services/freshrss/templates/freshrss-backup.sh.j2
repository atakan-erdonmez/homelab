#!/bin/bash
# Generated by Ansible - Manual changes will be overwritten

# 1. Set Restic Environment Variables
export RESTIC_REPOSITORY="{{ restic_repo }}"
export RESTIC_PASSWORD="{{ restic_password }}"
export RESTIC_CACHE_DIR="{{ restic_cache_dir }}"

# 2. Run the backup
echo "Starting FreshRSS backup to NAS..."
restic backup "{{ base_dir }}"

# 3. Apply retention policy (Keep 7 days)
echo "Cleaning up old snapshots..."
restic forget --keep-daily 7 --prune

echo "Backup completed successfully."