# Managed by Ansible - Changes will be overwritten
server {
    listen 8080;
    server_name {{ item.domain }};

    # Set body size for uploads (e.g., n8n binary data or file transfers)
    client_max_body_size {{ item.max_body_size | default('50M') }};

    location / {
        proxy_pass http://{{ item.ip }}:{{ item.port }};

        # Identity Headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # Protocol Fix: Essential for Cloudflare & CORS
        # Pass the original protocol (https) from Cloudflare to the app
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;


        {% if item.websockets | default(false) %}
        # --- Persistent Connection Support (WebSockets/SSE) ---
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Disable buffering to prevent "Lost connection" during streaming
        proxy_buffering off;
        proxy_cache off;
        chunked_transfer_encoding off;

        # Long timeouts for persistent pipes
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;


        {% else %}
        # --- Standard Web Application Settings ---
        proxy_buffering on;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
        {% endif %}

        proxy_connect_timeout 60s;
    }
}